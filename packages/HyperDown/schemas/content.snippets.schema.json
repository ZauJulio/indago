{
  "$schema": "http://json-schema.org/draft-07/schema",
  "description": "Defines the settings for Front Matter snippet",
  "lastModified": "2026-05-21T18:05:20.761Z",
  "type": "object",
  "title": "Front Matter - snippet",
  "required": ["body"],
  "properties": {
    "body": {
      "markdownDescription": "The snippet content.",
      "type": ["string", "array"],
      "items": {
        "type": "string"
      }
    },
    "title": {
      "description": "The snippet title.",
      "type": "string"
    },
    "description": {
      "description": "The snippet description.",
      "type": "string"
    },
    "fields": {
      "$ref": "media.contenttypes.schema.json#/properties/fields"
    },
    "openingTags": {
      "description": "The snippet opening tags.",
      "type": "string",
      "default": "[["
    },
    "closingTags": {
      "description": "The snippet closing tags.",
      "type": "string",
      "default": "]]"
    },
    "isMediaSnippet": {
      "description": "Specify if the snippet is to be used for media files.",
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false
}
