{
  "name": "@indago/hyper-down",
  "version": "1.3.1",
  "description": "Markdown/MDX → SQLite (FTS5 contentless) → server-side route loaders. A drop-in SSR headless CMS for Vike, React Router, TanStack Start, and Next.js — zero backend service.",
  "keywords": [
    "cms",
    "fts5",
    "full-text-search",
    "headless-cms",
    "markdown",
    "mcp",
    "mdx",
    "nextjs",
    "react",
    "react-router",
    "sqlite",
    "ssr",
    "static-site",
    "tanstack",
    "vike",
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://github.com/ZauJulio/indago/tree/main/packages/HyperDown",
  "bugs": {
    "url": "https://github.com/ZauJulio/indago/issues"
  },
  "license": "MIT",
  "author": "Zau Julio <zaujulio.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZauJulio/indago.git",
    "directory": "packages/HyperDown"
  },
  "bin": {
    "hyper-down": "./dist/bin/hyperdown.js",
    "hyperdown": "./dist/bin/hyperdown.js",
    "hyperdown-mcp": "./dist/bin/hyperdown-mcp.js"
  },
  "files": [
    "dist",
    "schemas",
    ".agents",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js",
      "default": "./dist/plugins.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "default": "./dist/next.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle.d.ts",
      "import": "./dist/drizzle.js",
      "default": "./dist/drizzle.js"
    },
    "./sidebar.css": "./dist/sidebar.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "bun run gen:types",
    "build": "tsdown",
    "cli": "bun cli/hyperdown.ts",
    "cli:init": "bun cli/hyperdown.ts init",
    "cli:validate": "bun cli/hyperdown.ts validate",
    "cli:update": "bun cli/hyperdown.ts update schemas",
    "cli:create-content": "bun cli/hyperdown.ts create-content",
    "cli:create-item": "bun cli/hyperdown.ts create-item",
    "gen:types": "bun scripts/gen-types.ts",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "check": "bun run lint && bun run format",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@mdx-js/rollup": "^3.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "github-slugger": "^2.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@repo/configs": "*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.9.0",
    "rolldown": "^1.0.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "mermaid": ">=10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^16.5.4 || ^17.0.0",
    "vite": "^8.0.14"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
