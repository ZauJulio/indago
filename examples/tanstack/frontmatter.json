{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "article",
      "pageBundle": false,
      "previewPath": "/articles",
      "fields": [
        { "title": "Title", "name": "title", "type": "string" },
        { "title": "Description", "name": "description", "type": "string" },
        {
          "title": "Publishing date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true
        },
        { "title": "Is in draft", "name": "draft", "type": "draft" },
        { "title": "Tags", "name": "tags", "type": "tags" },
        { "title": "Categories", "name": "categories", "type": "categories" },
        { "title": "Author", "name": "author", "type": "string" },
        { "title": "Reading Time", "name": "readingTime", "type": "string" },
        { "title": "Canonical URL", "name": "canonical", "type": "string" },
        { "title": "Cover", "name": "cover", "type": "string" }
      ]
    },
    {
      "name": "recipe",
      "pageBundle": false,
      "previewPath": "/cooking",
      "fields": [
        { "title": "Title", "name": "title", "type": "string" },
        { "title": "Description", "name": "description", "type": "string" },
        {
          "title": "Publishing date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true
        },
        { "title": "Is in draft", "name": "draft", "type": "draft" },
        { "title": "Tags", "name": "tags", "type": "tags" },
        { "title": "Cover", "name": "cover", "type": "string" },
        { "title": "Cuisine", "name": "cuisine", "type": "string" },
        { "title": "Meal Type", "name": "mealType", "type": "string" },
        { "title": "Course Type", "name": "courseType", "type": "string" },
        {
          "title": "Difficulty",
          "name": "difficulty",
          "type": "choice",
          "choices": ["easy", "medium", "hard"]
        },
        { "title": "Prep Time", "name": "prepTime", "type": "string" },
        { "title": "Cook Time", "name": "cookTime", "type": "string" },
        { "title": "Servings", "name": "servings", "type": "string" }
      ]
    }
  ],
  "frontMatter.framework.id": "other",
  "frontMatter.content.publicFolder": "",
  "frontMatter.content.i18n": [
    { "title": "English", "locale": "en", "path": "en" },
    { "title": "Português (Brasil)", "locale": "pt-BR", "path": "pt-BR" }
  ],
  "frontMatter.content.pageFolders": [
    {
      "title": "Articles",
      "path": "[[workspace]]/content/article",
      "filePrefix": "",
      "contentTypes": ["article"],
      "defaultLocale": "en",
      "locales": [
        { "title": "English", "locale": "en", "path": "en" },
        { "title": "Português (Brasil)", "locale": "pt-BR", "path": "pt-BR" }
      ]
    },
    {
      "title": "Recipes",
      "path": "[[workspace]]/content/recipe",
      "filePrefix": "",
      "contentTypes": ["recipe"],
      "defaultLocale": "en",
      "locales": [
        { "title": "English", "locale": "en", "path": "en" },
        { "title": "Português (Brasil)", "locale": "pt-BR", "path": "pt-BR" }
      ]
    }
  ],
  "frontMatter.git.enabled": true,
  "frontMatter.preview.host": "http://localhost:3000",
  "frontMatter.preview.pathName": "",
  "frontMatter.preview.trailingSlash": false
}
